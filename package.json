{
  "name": "mocha_rest_api_testing",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "mocha -r ts-node/register \"tests/**/*.ts\" --timeout 10000 --reporter mochawesome",
    "test:smoke": "mocha -r ts-node/register \"tests/**/*.ts\" --timeout 10000 --grep @smoke --reporter mochawesome",
    "test:regression": "mocha -r ts-node/register \"tests/**/*.ts\" --timeout 10000 --grep @regression --reporter mochawesome",
    "test:build": "mocha -r ts-node/register \"tests/**/*.ts\" --timeout 10000 --grep @build --reporter mochawesome --reporter-option reportDir=reports,reportFilename=$(node getReportName.js),overwrite=false",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syed-git/MOCHA_REST_API_TESTING.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/syed-git/MOCHA_REST_API_TESTING/issues"
  },
  "homepage": "https://github.com/syed-git/MOCHA_REST_API_TESTING#readme",
  "description": "",
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/cli-table": "^0.3.4",
    "@types/mocha": "^10.0.10",
    "@types/mochawesome": "^6.2.4",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "chai": "^6.0.1",
    "eslint": "^9.35.0",
    "mocha": "^11.7.2",
    "mocha-steps": "^1.3.0",
    "mocha-tags": "^1.0.1",
    "mochawesome": "^7.1.3",
    "mochawesome-report-generator": "^6.2.0",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table": "^0.3.11",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.47"
  }
}
